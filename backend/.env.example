# ---- Server ----
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safe_journal?schema=public

# ---- JWT ----
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_a_random_64_char_hex_string
JWT_REFRESH_SECRET=replace_with_a_different_random_64_char_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- Cookies ----
COOKIE_SECRET=replace_with_another_random_64_char_hex_string

# ---- Redis (BullMQ background jobs — only used by `npm run worker` / the
# `worker` docker-compose service; the core API never opens a Redis connection
# and will run fine locally even if Redis isn't installed/running) ----
REDIS_URL=redis://localhost:6379

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM=Safe Journal <no-reply@safejournal.app>

# ---- File storage (Cloudinary) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- AI provider ----
# One of: anthropic | openai | mock
# "mock" requires no API key and returns canned responses — useful for local dev.
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=claude-sonnet-5

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ---- Logging ----
LOG_LEVEL=info
